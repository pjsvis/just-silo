# Blog-Writer Silo justfile
# Transform wee stories into polished blog posts

set shell := ["bash", "-o", "pipefail", "-c"]
set positional-arguments := true

# ============================================================
# METADATA
# ============================================================

PROJECT_NAME := "blog-writer-silo"
VERSION := "0.1.0"
STORIES_FILE := "../stories/stories.jsonl"

# ============================================================
# HELP
# ============================================================

help:
    @echo "{{ PROJECT_NAME }} v{{ VERSION }}"
    @echo ""
    @echo "Usage: just [command]"
    @echo ""
    @echo "Commands:"
    @echo "  just draft TOPIC [STORIES]    Create draft from stories"
    @echo "  just render FILE             Render draft to post"
    @echo "  just publish FILE           Publish draft"
    @echo "  just stats                  Story availability stats"
    @echo "  just list                   List available stories"
    @echo "  just search TAG             Search stories by tag"
    @echo "  just provision              Set up silo"
    @echo "  just verify                 Verify dependencies"
    @echo ""

# ============================================================
# CORE WORKFLOW
# ============================================================

# Create draft from stories
# Usage: just draft TOPIC [STORIES=6] [TEMPLATE=default]
draft topic stories=("6") template=("default"):
    @echo "=== Creating Draft ==="
    @echo "Topic: {{topic}}"
    @echo "Stories: {{stories}}"
    @echo "Template: {{template}}"
    @echo ""
    @bash scripts/draft.sh "{{topic}}" "{{stories}}" "{{template}}"

# Render draft to final post
# Usage: just render FILE
render file:
    @echo "=== Rendering Draft ==="
    @echo "File: {{file}}"
    @bash scripts/render.sh "{{file}}"

# Publish draft to posts/
# Usage: just publish FILE
publish file:
    @echo "=== Publishing ==="
    @bash scripts/publish.sh "{{file}}"

# ============================================================
# STORY MANAGEMENT
# ============================================================

# List available stories
list:
    @bash scripts/list-stories.sh

# Story availability stats
stats:
    @echo "=== Story Availability ==="
    @jq -n '[inputs]' "{{STORIES_FILE}}" > /dev/null 2>&1 && \
        jq -n '[inputs] | {total: length, by_type: group_by(.type) | map({type: .[0].type, count: length}), by_quality: {high: ([.[] | select(.quality >= 0.35)] | length), medium: ([.[] | select(.quality >= 0.2 and .quality < 0.35)] | length), low: ([.[] | select(.quality < 0.2)] | length)}, by_topic: group_by(.tags[0]) | map({topic: .[0].tags[0], count: length}) | sort_by(.count) | reverse | .[:10]}' "{{STORIES_FILE}}" || \
        echo "No stories found. Run story-scan.sh first."

# Search stories by tag
# Usage: just search TAG
search tag:
    @echo "=== Searching: {{tag}} ==="
    @bash scripts/list-stories.sh --tag "{{tag}}"

# Search by type
# Usage: just search-type TYPE
search-type type:
    @echo "=== Type: {{type}} ==="
    @bash scripts/list-stories.sh --type "{{type}}"

# Show high quality stories
high-quality:
    @echo "=== High Quality Stories (≥0.35) ==="
    @jq -n '[inputs | select(.quality >= 0.35)] | .[] | "\(.quality) [\(.|.type)] \(.narrative[0:100])..."' "{{STORIES_FILE}}"

# ============================================================
# DRAFT MANAGEMENT
# ============================================================

# List drafts
list-drafts:
    @echo "=== Drafts ==="
    @ls -la drafts/ 2>/dev/null || echo "No drafts directory"

# Show status
status:
    @bash scripts/status.sh list

# Remove draft
# Usage: just rm-draft FILE
rm-draft file:
    @echo "Removing: drafts/{{file}}"
    @rm -f "drafts/{{file}}"
    @bash scripts/status.sh rm-draft "drafts/{{file}}" 2>/dev/null || true

# ============================================================
# MAINTENANCE
# ============================================================

# Backup drafts to archive
backup:
    @echo "=== Backing Up Drafts ==="
    @mkdir -p drafts/_archive
    @cp -r drafts/*.md drafts/_archive/ 2>/dev/null || echo "No drafts to backup"
    @echo "Backup complete"

# Purge old drafts
purge days=("7"):
    @echo "=== Purging Drafts Older Than {{days}} Days ==="
    @find drafts/ -name "*.md" -mtime +{{days}} -exec rm -v {} \; 2>/dev/null || echo "Nothing to purge"

# Show audit log
audit limit=("20"):
    @bash scripts/audit.sh stats || echo "No audit log"

# List audit events
audit-log limit=("20"):
    @bash scripts/audit.sh read "" "{{limit}}" || echo "No audit log"

# ============================================================
# PROVISIONING
# ============================================================

# Verify dependencies
verify:
    @echo "=== Verifying Dependencies ==="
    @echo -n "Stories file: "
    @test -f "{{STORIES_FILE}}" && echo "✓ exists" || echo "✗ missing"
    @echo -n "Templates: "
    @test -d "templates" && echo "✓ exists" || echo "✗ missing"
    @echo -n "Scripts: "
    @test -d "scripts" && echo "✓ exists" || echo "✗ missing"
    @echo -n "Schema: "
    @test -f "schema.json" && echo "✓ exists" || echo "✗ missing"
    @echo -n "jq: "
    @which jq > /dev/null && echo "✓ installed" || echo "✗ missing"
    @echo ""
    @echo "Stories count: $$(jq -n '[inputs] | length' '{{STORIES_FILE}}' 2>/dev/null || echo 0)"

# Provision the silo
provision:
    @echo "=== Provisioning {{ PROJECT_NAME }} ==="
    @bash scripts/provision.sh

# Reset silo (clean slate)
reset:
    @echo "=== Resetting Silo ==="
    @rm -rf drafts/*.md 2>/dev/null || true
    @mkdir -p drafts/_archive
    @echo "Silo reset complete"

# ============================================================
# AGENTS
# ============================================================

# Run blog agent for assisted authoring
agent task=("weave"):
    @echo "=== Blog Agent: {{task}} ==="
    @bash agents/blog-agent/run.sh "{{task}}"

# ============================================================
# DEVELOPMENT
# ============================================================

# Validate schema
validate:
    @echo "=== Validating Schema ==="
    @jq empty schema.json && echo "✓ schema.json is valid" || echo "✗ schema.json has errors"

# Test template rendering
test-template template=("default"):
    @echo "=== Testing Template: {{template}} ==="
    @cat "templates/{{template}}.md"

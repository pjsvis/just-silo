{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Blog-Writer Silo Schema",
  "description": "Schema for stories and drafts in blog-writer-silo",
  
  "story": {
    "type": "object",
    "required": ["id", "source", "type", "narrative", "quality"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
      },
      "source": {
        "type": "string",
        "description": "Source file path"
      },
      "type": {
        "type": "string",
        "enum": ["origin", "lesson", "insight", "anti-pattern"]
      },
      "narrative": {
        "type": "string",
        "minLength": 60,
        "maxLength": 400
      },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      },
      "quality": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "usefulness": {
        "type": "string",
        "enum": ["high", "medium", "low"]
      },
      "created": {
        "type": "string",
        "format": "date-time"
      }
    }
  },

  "draft": {
    "type": "object",
    "required": ["title", "topic", "date", "content"],
    "properties": {
      "title": {
        "type": "string",
        "minLength": 3
      },
      "topic": {
        "type": "string"
      },
      "date": {
        "type": "string",
        "format": "date"
      },
      "template": {
        "type": "string"
      },
      "story_ids": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
        }
      },
      "content": {
        "type": "string"
      }
    }
  },

  "post": {
    "type": "object",
    "required": ["title", "topic", "date", "content"],
    "properties": {
      "title": {
        "type": "string",
        "minLength": 3
      },
      "topic": {
        "type": "string"
      },
      "date": {
        "type": "string",
        "format": "date"
      },
      "tags": {
        "type": "array",
        "items": { "type": "string" }
      },
      "content": {
        "type": "string"
      },
      "published": {
        "type": "boolean"
      }
    }
  },

  "story_reference": {
    "type": "object",
    "required": ["id", "type", "quality"],
    "properties": {
      "id": { "type": "string" },
      "type": { "type": "string" },
      "quality": { "type": "number" },
      "slot": { "type": "string" },
      "section": { "type": "string" }
    }
  }
}

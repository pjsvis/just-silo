{
  "plan": {
    "type": "object",
    "required": ["title", "topic", "status", "created"],
    "properties": {
      "title": { "type": "string" },
      "topic": { "type": "string" },
      "status": { "type": "string", "enum": ["planned", "drafting", "draft", "review", "published"] },
      "created": { "type": "string" },
      "updated": { "type": "string" },
      "tags": { "type": "array", "items": { "type": "string" } },
      "sections": { "type": "array", "items": { "type": "string" } },
      "stories": { "type": "array", "items": { "type": "string" } },
      "notes": { "type": "string" },
      "draft": { "type": "string", "description": "Path to draft file" },
      "post": { "type": "string", "description": "Path to final post" }
    }
  }
}

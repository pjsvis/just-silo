# Blog Writer Silo - Development Workspace
# From: dev/blog_writer_silo/
# Parent: ../../
# Stories: ../../stories/stories.jsonl

set shell := ["bash", "-o", "pipefail", "-c"]

# ============================================================
# DEVELOPMENT
# ============================================================

dev:
    @echo "=== blog_writer_silo Development ==="
    @echo "Workspace: dev/blog_writer_silo"
    @echo ""
    @echo "Commands:"
    @echo "  just verify   - Check parent resources"
    @echo "  just stats   - Story statistics"
    @echo "  just draft   - Create a draft (just draft TOPIC)"

verify:
    @echo "=== Parent Resources ==="
    @test -f "../../stories/stories.jsonl" && echo "✓ Stories" || echo "✗ No stories"
    @test -d "../../scripts" && echo "✓ Scripts" || echo "✗ No scripts"

# ============================================================
# STORIES
# ============================================================

stats:
    @echo "=== Story Stats ==="
    @cd ../.. && just blog-list 2>&1 | head -50

stories:
    @echo "=== Available Stories ==="
    @cd ../.. && just blog-list --all 2>&1 | head -80

hq:
    @echo "=== High Quality Stories (≥0.35) ==="
    @cd ../.. && jq -n '[inputs | select(.quality >= 0.35)] | .[] | "\(.quality) [\(.type)] \(.narrative[0:80])..."' ../../stories/stories.jsonl

by-topic topic:
    @cd ../.. && jq -n --arg t "{{topic}}" '[inputs | select(.tags | index($t) != null)] | .[] | "\(.quality) [\(.type)] \(.narrative[0:100])..."' ../../stories/stories.jsonl

# ============================================================
# DRAFT WORKFLOW
# ============================================================

# Create draft from topic
draft topic count=("5"):
    @echo "=== Creating Draft: {{topic}} ==="
    @bash scripts/draft.sh "{{topic}}" "{{count}}"

# List drafts
drafts:
    @echo "=== Drafts ==="
    @ls -la drafts/ 2>/dev/null || echo "(none)"

# Render draft to post
render draft:
    @echo "=== Rendering ==="
    @bash scripts/render.sh "{{draft}}"

# Publish draft
publish draft:
    @echo "=== Publishing ==="
    @bash scripts/publish.sh "{{draft}}"

# List posts
posts:
    @echo "=== Posts ==="
    @ls -la posts/ 2>/dev/null || echo "(none)"

# ============================================================
# TEMPLATES
# ============================================================

templates:
    @echo "=== Templates ==="
    @ls -la templates/

{
  "name": "blog_writer_silo",
  "version": "0.1.0",
  "domain": "blog-authoring",
  "parent": "just-silo",
  "created": "2026-04-12",
  "status": "development",
  "description": "Blog authoring workflow using wee stories from documentation",
  "lexicon": {
    "story": "A compact narrative element with id, source, type, narrative, tags, quality",
    "wee-story": "A small, self-contained anecdote (2-5 sentences)",
    "draft": "Working document with embedded story references",
    "render": "Convert draft to final post"
  },
  "dev_path": "../../",
  "deps": ["stories/stories.jsonl"],
  "resources": {
    "stories": "../../stories/stories.jsonl",
    "briefs": "../../briefs/"
  },
  "phases": [
    "browse - Explore available stories",
    "draft - Create draft from template + stories",
    "edit - Manually refine draft",
    "render - Convert to final post",
    "publish - Archive draft, finalize post"
  ]
}

{
  "$schema": "https://github.com/marcus-nicolaou/just-silo/blob/main/schemas/silo-manifest.schema.json",
  "name": "{{name}}",
  "version": "1.0.0",
  "domain": "{{domain}}",
  "description": "{{description}}",
  "created": "{{created}}",
  "owner": "{{owner}}",
  "visibility": "{{visibility}}",
  "silo_type": "generic",
  "blast_radius": 1,
  "workspace": {
    "locked": false,
    "machine_id": null,
    "mounts": {}
  },
  "security": {
    "sandboxed": true,
    "network_access": "restricted",
    "filesystem_scope": "local",
    "resource_limits": {
      "max_memory_mb": 512,
      "max_cpu_percent": 50,
      "max_disk_mb": 100
    }
  },
  "#meta": {
    "naming": {
      "private_convention": "Names starting with _ are private/local-only",
      "public_convention": "Names without prefix are shared/synced"
    },
    "stratification": {
      "scaffold": [
        "justfile",
        "schema.json",
        "queries.json",
        "process.sh",
        "scripts/",
        ".silo"
      ],
      "throughput": [
        "data.jsonl",
        "harvest.jsonl",
        "quarantine.jsonl",
        "final_output.jsonl",
        "markers/",
        "pipeline.json",
        "status.json",
        "audit.jsonl"
      ],
      "rationale": "Scaffold files are versioned, shared, rarely change. Throughput files are local, ephemeral, change every run."
    }
  },
  "toolchain": {
    "runtime": "bun",
    "linter": "oxlint",
    "formatter": "biome",
    "shell": "bash"
  },
  "audit": {
    "enabled": true,
    "file": "audit.jsonl",
    "events": [
      "harvest_start",
      "harvest_complete",
      "harvest_failed",
      "process_start",
      "process_complete",
      "process_failed",
      "flush_start",
      "flush_complete",
      "flush_failed",
      "alert",
      "error",
      "checkpoint"
    ]
  },
  "interface": {
    "engine": "justfile",
    "schema": "schema.json",
    "queries": "queries.json",
    "input": "harvest.jsonl",
    "active_state": "data.jsonl",
    "quarantine": "quarantine.jsonl",
    "output": "final_output.jsonl"
  },
  "phases": [
    "verify",
    "harvest",
    "process",
    "observe",
    "flush"
  ],
  "thresholds": {},
  "references": [],
  "lexicon": {
    "harvest": "Ingest and validate data against schema",
    "process": "Transform and enrich data",
    "flush": "Archive processed entries to output",
    "observe": "Check pipeline health and alerts",
    "verify": "Confirm prerequisites are met"
  }
}

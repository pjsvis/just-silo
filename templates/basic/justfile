# Silo Vocabulary
# Generated from templates/basic

# === DATA STRATIFICATION ===
# Scaffold files: versioned, shared, rarely change (.silo, justfile, schema, queries, process.sh)
# Throughput files: local, ephemeral, change every run (data.jsonl, harvest.jsonl, output)
# See: .silo["#meta"]["stratification"] for full manifest

set shell := ["bash", "-o", "pipefail", "-c"]
set export := true

DATA_FILE      := "data.jsonl"
HARVEST_FILE   := "harvest.jsonl"
QUARANTINE_FILE := "quarantine.jsonl"
OUTPUT_FILE    := "final_output.jsonl"
SCHEMA_FILE    := "schema.json"
QUERIES_FILE   := "queries.json"
PIPELINE_FILE  := "pipeline.json"
MARKERS_DIR    := "markers"
SCRIPTS_DIR    := "scripts"
AUDIT_FILE     := "audit.jsonl"

# === ENTRY POINT ===

default:
    @echo "=== silo Silo ==="
    @echo "Recipes:"
    @just --list --justfile {{justfile()}} 2>&1 | grep -v "^#" | grep -v "Available recipes" | grep -v "^$"
    @echo ""
    @echo "Run 'just help' for overview"
    @echo ""
    @echo "Workspace: $([ -f .silo ] && jq -r '.workspace.machine_id // "unlocked"' .silo 2>/dev/null || echo "unlocked")"

# === HELP ===

help:
    @echo "HELP - Available commands:"
    @echo "  just verify           - Check prerequisites"
    @echo "  just harvest [source] - Ingest + validate data"
    @echo "  just process          - Transform data"
    @echo "  just flush           - Archive to output"
    @echo "  just status          - Pipeline observability"
    @echo "  just stats           - Show counts"
    @echo "  just report          - Full report"
    @echo "  just lock            - Lock silo to this machine"
    @echo "  just chart           - Show throughput visualization"

# === CORE PIPELINE ===

# Verify prerequisites are installed
verify:
    @echo "Checking prerequisites..."
    @test -f {{SCHEMA_FILE}} && echo "  ✓ schema.json" || echo "  ✗ MISSING schema.json"
    @test -f {{QUERIES_FILE}} && echo "  ✓ queries.json" || echo "  ✗ MISSING queries.json"
    @command -v jq >/dev/null 2>&1 && echo "  ✓ jq" || echo "  ✗ jq MISSING"
    @command -v just >/dev/null 2>&1 && echo "  ✓ just" || echo "  ✗ just MISSING"
    @command -v glow >/dev/null 2>&1 && echo "  ○ glow (optional)" || true
    @command -v gum >/dev/null 2>&1 && echo "  ○ gum (optional)" || true

# Ingest data and validate against schema
harvest source=(HARVEST_FILE):
    @./{{SCRIPTS_DIR}}/audit_log.sh harvest_start source={{source}}
    @just verify
    @if [ ! -f "{{source}}" ]; then \
        ./{{SCRIPTS_DIR}}/audit_log.sh harvest_failed error="source_not_found" source={{source}}; \
        echo "ERROR: '{{source}}' not found"; exit 1; \
    fi
    @echo "Harvesting from {{source}}..."
    @> {{DATA_FILE}} && > {{QUARANTINE_FILE}}
    @cat {{source}} | jq -c '.' >> {{DATA_FILE}} 2>/dev/null || true
    @./{{SCRIPTS_DIR}}/audit_log.sh harvest_complete count=$(cat {{DATA_FILE}} | wc -l)
    @just stats

# Run domain transformation
process:
    @./process.sh

# Move processed entries to final output
flush:
    @./{{SCRIPTS_DIR}}/audit_log.sh flush_start
    @if [ ! -f {{DATA_FILE}} ]; then \
        ./{{SCRIPTS_DIR}}/audit_log.sh flush_complete count=0 reason="no_data"; \
        echo "Nothing to flush"; exit 0; \
    fi
    @FLUSHED=$$(jq -c 'select(.status == "processed")' {{DATA_FILE}} >> {{OUTPUT_FILE}} 2>/dev/null && jq -s 'length' {{OUTPUT_FILE}} || echo 0)
    @jq -c 'select(.status != "processed")' {{DATA_FILE}} > {{DATA_FILE}}.tmp
    @mv {{DATA_FILE}}.tmp {{DATA_FILE}}
    @./{{SCRIPTS_DIR}}/audit_log.sh flush_complete count=$$FLUSHED
    @just stats

# === AUDIT TRAIL ===

# Query audit log
audit-q filter=(".event"):
    @if [ -f "{{AUDIT_FILE}}" ]; then jq -c "{{filter}}" "{{AUDIT_FILE}}" 2>/dev/null || echo "No audit entries"; else echo "No audit log found"; fi

# Tail audit log
audit-tail n=("10"):
    @if [ -f "{{AUDIT_FILE}}" ]; then tail -n {{n}} "{{AUDIT_FILE}}"; else echo "No audit log found"; fi

# Show event types
audit-events:
    @just audit-q '.event' | sort | uniq -c | sort -rn

# Show timeline
audit-timeline:
    @just audit-q '.' | jq -s 'sort_by(.timestamp) | reverse | .[] | "\(.timestamp | split("T")[1] | split(".")[0]) \(.event)"' 2>/dev/null || echo "No timeline"

# === OBSERVE: Pipeline Health ===

status-json:
    @./{{SCRIPTS_DIR}}/status_json.sh

status:
    @./{{SCRIPTS_DIR}}/status_plain.sh

who:
    @echo "AGENTS:"
    @if [ -f {{PIPELINE_FILE}} ]; then jq -r '.stages[] | "  \(.id): \(.agent // "unassigned")"' {{PIPELINE_FILE}}; fi

stuck threshold="60":
    @./{{SCRIPTS_DIR}}/status_stuck.sh {{threshold}}

throughput:
    @echo "Active:     $([ -f {{DATA_FILE}} ] && jq -s 'length' {{DATA_FILE}} || echo 0)"
    @echo "Quarantine: $([ -f {{QUARANTINE_FILE}} ] && jq -s 'length' {{QUARANTINE_FILE}} || echo 0)"
    @echo "Output:     $([ -f {{OUTPUT_FILE}} ] && jq -s 'length' {{OUTPUT_FILE}} || echo 0)"

stats:
    @just throughput

# === MARKDOWN-UI ===

# Render README with live status
render:
    @./{{SCRIPTS_DIR}}/render_status.sh --stdout

# Render with glow (if installed)
render-glow:
    @./{{SCRIPTS_DIR}}/render_status.sh --glow

# Show data stratification overview
stratify:
    @echo "=== DATA STRATIFICATION ==="
    @echo ""
    @echo "SCAFFOLD (git-tracked):"
    @echo "  - .silo          (manifest)"
    @echo "  - justfile       (interface)"
    @echo "  - schema.json    (validation)"
    @echo "  - queries.json   (filters)"
    @echo "  - process.sh     (domain logic)"
    @echo "  - scripts/       (utilities)"
    @echo ""
    @echo "THROUGHPUT (git-ignored):"
    @echo "  - data.jsonl     (working set)"
    @echo "  - harvest.jsonl  (raw input)"
    @echo "  - quarantine.jsonl (rejected)"
    @echo "  - final_output.jsonl (archived)"
    @echo "  - markers/       (coordination)"
    @echo "  - pipeline.json  (state)"
    @echo "  - status.json    (health)"
    @echo "  - audit.jsonl    (event log)"

alerts:
    @if [ -f {{DATA_FILE}} ]; then jq -c 'select(.alert == true)' {{DATA_FILE}} || echo "  (no alerts)"; else echo "  (no data)"; fi

report:
    @just stats && just alerts

# === MULTI-AGENT COORDINATION ===

claim stage:
    @mkdir -p {{MARKERS_DIR}}
    @AGENT_ID=$$(hostname -s)_$$(date +%s)
    @echo "{\"agent\":\"$$AGENT_ID\",\"stage\":\"{{stage}}\",\"claimed\":\"$$(date -Iseconds)\"}" > {{MARKERS_DIR}}/{{stage}}.lock
    @echo "CLAIMED: {{stage}}"

done marker:
    @mkdir -p {{MARKERS_DIR}}
    @if [ -f {{MARKERS_DIR}}/{{marker}}.lock ]; then mv {{MARKERS_DIR}}/{{marker}}.lock {{MARKERS_DIR}}/{{marker}}.done; fi
    @touch {{MARKERS_DIR}}/{{marker}}.done
    @echo "DONE: {{marker}}"

wait marker:
    @mkdir -p {{MARKERS_DIR}}
    @echo "Waiting for {{marker}}..."
    @while [ ! -f {{MARKERS_DIR}}/{{marker}}.lock ] && [ ! -f {{MARKERS_DIR}}/{{marker}}.done ]; do sleep 5; done
    @echo "{{marker}} ready"

heartbeat:
    @mkdir -p {{MARKERS_DIR}}
    @for l in {{MARKERS_DIR}}/*.lock; do if [ -f "$$l" ]; then touch "$$l"; fi; done
    @echo "Heartbeats recorded"

# === GAMMA LOOP: SELF-IMPROVEMENT ===

# Analyze silo performance
gamma-analyze:
    @./{{SCRIPTS_DIR}}/gamma_loop.sh analyze

# Get recommendations
gamma-recommend:
    @./{{SCRIPTS_DIR}}/gamma_loop.sh recommend

# Preview threshold adjustments
gamma-adjust:
    @./{{SCRIPTS_DIR}}/gamma_loop.sh adjust

# Full gamma loop
gamma:
    @./{{SCRIPTS_DIR}}/gamma_loop.sh all

# === WORKSPACE LOCK ===

# Lock silo to this machine
lock:
    @./{{SCRIPTS_DIR}}/workspace_lock.sh lock

# Unlock silo
unlock:
    @./{{SCRIPTS_DIR}}/workspace_lock.sh unlock

# Check lock status
check-lock:
    @./{{SCRIPTS_DIR}}/workspace_lock.sh check

# === SECURITY ===

# Validate a script for dangerous patterns
validate-scripts:
    @echo "Validating scripts..."
    @for s in {{SCRIPTS_DIR}}/*.sh; do \
        ./{{SCRIPTS_DIR}}/sandbox.sh validate "$$s" 2>&1 || true; \
    done

# Show security config
security:
    @echo "=== SECURITY CONFIG ==="
    @jq '.security' .silo 2>/dev/null || echo "No security config"

# === UTILITIES ===

query filter:
    @FILTER_JQ=$$(jq -r '.filters["{{filter}}"].jq' {{QUERIES_FILE}})
    @jq -c "$$FILTER_JQ" {{DATA_FILE}}

self-test:
    @just verify
    @echo "SELF-TEST: PASSED"

clean:
    @rm -f {{DATA_FILE}} {{QUARANTINE_FILE}} {{OUTPUT_FILE}}
    @echo "Cleaned data files"

install-deps:
    @command -v jq >/dev/null 2>&1 && echo "jq: ✓" || echo "jq: ✗"
    @command -v just >/dev/null 2>&1 && echo "just: ✓" || echo "just: ✗"
    @command -v glow >/dev/null 2>&1 && echo "glow: ✓" || echo "glow: ○"
    @command -v gum >/dev/null 2>&1 && echo "gum: ✓" || echo "gum: ○"

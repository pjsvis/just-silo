# google-docs-sync.env.example
#
# Copy to:
#   scripts/google-docs-sync.env
# Then edit values for your environment.
#
# Usage:
#   ./scripts/google-docs-sync.sh --config scripts/google-docs-sync.env --print-config
#   ./scripts/google-docs-sync.sh --config scripts/google-docs-sync.env
#
# Notes:
# - This file is sourced by bash (KEY=value format).
# - Do NOT commit real secrets/credentials.
# - rclone auth/config is stored in rclone's own config, not here.

# ------------------------------------------------------------
# Core rclone config
# ------------------------------------------------------------

# Name of your configured rclone remote
# Example:
#   rclone config
#   # create remote named "gdrive"
RCLONE_REMOTE=gdrive

# Optional base path in the remote under which your folder structure lives.
# Leave empty to use remote root.
# Examples:
#   RCLONE_BASE_PATH=just-silo
#   RCLONE_BASE_PATH=Shared/KnowledgeBase
RCLONE_BASE_PATH=

# Preferred Google Docs export formats (in order).
# Keep markdown first for QMD workflows.
RCLONE_EXPORT_FORMATS=md,txt,docx

# Optional extra flags passed to rclone sync.
# Keep empty unless you know exactly what you want.
# Examples:
#   RCLONE_EXTRA_FLAGS=--fast-list
#   RCLONE_EXTRA_FLAGS=--verbose
RCLONE_EXTRA_FLAGS=

# Check remote availability before syncing (1=true, 0=false)
RCLONE_CHECK_REMOTE=1

# ------------------------------------------------------------
# Local target folders (relative to repo root)
# ------------------------------------------------------------

LOCAL_BRIEFS_DIR=briefs
LOCAL_DEBRIEFS_DIR=debriefs
LOCAL_BRIEFS_ARCHIVE_DIR=briefs_archive
LOCAL_DEBRIEFS_ARCHIVE_DIR=debriefs_archive

# ------------------------------------------------------------
# Remote subpaths (relative to RCLONE_BASE_PATH)
# ------------------------------------------------------------

REMOTE_BRIEFS_SUBPATH=briefs
REMOTE_DEBRIEFS_SUBPATH=debriefs
REMOTE_BRIEFS_ARCHIVE_SUBPATH=briefs_archive
REMOTE_DEBRIEFS_ARCHIVE_SUBPATH=debriefs_archive

# ------------------------------------------------------------
# Sync behavior
# ------------------------------------------------------------

# Collection selector:
#   all | briefs | debriefs | briefs-archive | debriefs-archive
ONLY_COLLECTION=all

# Run QMD refresh after sync (1=true, 0=false)
RUN_QMD_REFRESH=1

# Minimum markdown file thresholds per collection (safety check).
# Set >0 to guard against accidental empty syncs from wrong folder paths.
# Leave 0 to disable check.
MIN_FILES_BRIEFS=0
MIN_FILES_DEBRIEFS=0
MIN_FILES_BRIEFS_ARCHIVE=0
MIN_FILES_DEBRIEFS_ARCHIVE=0

# ------------------------------------------------------------
# Example profile (uncomment + edit)
# ------------------------------------------------------------
# RCLONE_REMOTE=gdrive
# RCLONE_BASE_PATH=just-silo-docs
# REMOTE_BRIEFS_SUBPATH=active/briefs
# REMOTE_DEBRIEFS_SUBPATH=active/debriefs
# REMOTE_BRIEFS_ARCHIVE_SUBPATH=archive/briefs
# REMOTE_DEBRIEFS_ARCHIVE_SUBPATH=archive/debriefs
# MIN_FILES_BRIEFS=5
# MIN_FILES_DEBRIEFS=2
# RUN_QMD_REFRESH=1

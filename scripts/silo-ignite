#!/usr/bin/env bash
# silo-ignite - Clone, configure, and initialize a new silo
# Usage: silo-ignite <name> [options]
#
# This is the "Clone, Ignite, Spawn" user journey:
# 1. Create silo from template (silo-create)
# 2. Configure for local environment
# 3. Initialize dependencies
# 4. Verify readiness

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SILO_CREATE="$SCRIPT_DIR/silo-create"
REGISTER_DIR="${REGISTER_DIR:-$HOME/vault/the-register}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

usage() {
    cat << EOF
silo-ignite - Full silo bootstrap: create + configure + init

USAGE:
    silo-ignite <name> [options]

OPTIONS:
    -t, --template   Template to use (default: basic)
    -d, --domain     Domain for this silo
    -o, --owner      Owner identifier
    -p, --path       Parent directory
    --skip-init      Skip initialization step
    --skip-verify    Skip verification step
    -h, --help       Show this help

EXAMPLES:
    silo-ignite my-project --domain "ai-infra"
    silo-ignite my-project -t basic -d monitoring -o admin

USER JOURNEY:
    1. CREATE  - Scaffold from template (silo-create)
    2. CONFIGURE - Set up local config
    3. INIT    - Install dependencies
    4. VERIFY  - Confirm readiness

EOF
}

log() { echo -e "${GREEN}[silo-ignite]${NC} $1"; }
info() { echo -e "${BLUE}[silo-ignite]${NC} $1"; }
warn() { echo -e "${YELLOW}[silo-ignite]${NC} WARNING: $1"; }
error() { echo -e "${RED}[silo-ignite]${NC} ERROR: $1" >&2; }

# Parse arguments
NAME=""
TEMPLATE="basic"
DOMAIN=""
OWNER="${USER:-$(whoami)}"
PARENT_DIR="${PWD}"
SKIP_INIT=false
SKIP_VERIFY=false

while [[ $# -gt 0 ]]; do
    case $1 in
        -t|--template) TEMPLATE="$2"; shift 2 ;;
        -d|--domain) DOMAIN="$2"; shift 2 ;;
        -o|--owner) OWNER="$2"; shift 2 ;;
        -p|--path) PARENT_DIR="$2"; shift 2 ;;
        --skip-init) SKIP_INIT=true; shift ;;
        --skip-verify) SKIP_VERIFY=true; shift ;;
        -h|--help) usage; exit 0 ;;
        -*) error "Unknown option: $1"; exit 1 ;;
        *) NAME="$1"; shift ;;
    esac
done

# Validate
if [ -z "$NAME" ]; then
    error "Name is required"
    usage
    exit 1
fi

# Default domain if not specified
if [ -z "$DOMAIN" ]; then
    DOMAIN="unassigned"
fi

# Paths
SILO_DIR="$PARENT_DIR/$NAME"

# ============================================
# STEP 1: CREATE
# ============================================
log "STEP 1: Creating silo..."
if [ -d "$SILO_DIR" ]; then
    warn "Silo already exists: $SILO_DIR"
    info "Skipping create step..."
else
    if [ -x "$SILO_CREATE" ]; then
        "$SILO_CREATE" "$NAME" \
            --template "$TEMPLATE" \
            --domain "$DOMAIN" \
            --owner "$OWNER" \
            --path "$PARENT_DIR"
    else
        # Fallback: manual create
        warn "silo-create not found, creating manually..."
        mkdir -p "$SILO_DIR"
    fi
fi

cd "$SILO_DIR"

# ============================================
# STEP 2: CONFIGURE
# ============================================
log "STEP 2: Configuring for local environment..."

# Create local config (gitignored)
if [ ! -f ".silo.local" ]; then
    cat > ".silo.local" << EOF
{
  "name": "$NAME",
  "initialized": "$(date -Iseconds)",
  "register": "${REGISTER_DIR:-none}",
  "config": {}
}
EOF
    info "Created .silo.local (local overrides)"
fi

# Create .gitignore if not exists
if [ ! -f ".gitignore" ]; then
    cat > ".gitignore" << EOF
# Local config (contains paths)
.silo.local

# Data files
data.jsonl
harvest.jsonl
quarantine.jsonl
final_output.jsonl

# Logs
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
EOF
    info "Created .gitignore"
fi

# ============================================
# STEP 3: INIT
# ============================================
if [ "$SKIP_INIT" = true ]; then
    info "Skipping init (--skip-init specified)"
else
    log "STEP 3: Initializing dependencies..."
    
    # Try just init first
    if command -v just >/dev/null 2>&1; then
        if [ -f "justfile" ]; then
            just init 2>/dev/null || true
        fi
    fi
    
    # Check for package.json
    if [ -f "package.json" ]; then
        info "Installing npm dependencies..."
        npm install 2>/dev/null || bun install 2>/dev/null || yarn 2>/dev/null || true
    fi
    
    # Check for bun.lockb
    if [ -f "bun.lockb" ]; then
        info "Bun dependencies already installed"
    fi
fi

# ============================================
# STEP 4: VERIFY
# ============================================
if [ "$SKIP_VERIFY" = true ]; then
    info "Skipping verify (--skip-verify specified)"
else
    log "STEP 4: Verifying readiness..."
    
    if command -v just >/dev/null 2>&1 && [ -f "justfile" ]; then
        just verify
    else
        warn "just not found or no justfile - manual verification needed"
    fi
fi

# ============================================
# SUMMARY
# ============================================
echo ""
log "========================================"
log "Silo ignited: ${GREEN}$NAME${NC}"
log "========================================"
echo ""
log "Location: $SILO_DIR"
log "Domain: $DOMAIN"
log "Owner: $OWNER"
log ""
info "Next steps:"
info "  cd $NAME"
info "  just harvest        # Ingest data"
info "  just process        # Transform data"
info "  just status         # Check health"
info "  just flush          # Archive output"
echo ""
info "To sync with The Register:"
info "  just sync"
info ""

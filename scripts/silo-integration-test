#!/usr/bin/env bash
# silo-integration-test - End-to-end test of silo creation and execution
# "Hotel in Paris" - the proof that the whole system works

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEST_DIR="${SILO_TEST_DIR:-/tmp/silo-integration-test}"
SILO_IGNITE="$SCRIPT_DIR/silo-ignite"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PASS=0
FAIL=0

log_pass() { echo -e "${GREEN}[PASS]${NC} $1"; PASS=$((PASS+1)); }
log_fail() { echo -e "${RED}[FAIL]${NC} $1"; FAIL=$((FAIL+1)); }
log_info() { echo -e "${YELLOW}[TEST]${NC} $1"; }

cleanup() {
    log_info "Cleaning up..."
    rm -rf "$TEST_DIR"
}

trap cleanup EXIT

# Start test
echo "========================================"
echo "Silo Integration Test"
echo "========================================"
echo ""

# Setup
TEST_DIR="/tmp/silo-integration-test-$$"
mkdir -p "$TEST_DIR"
cd "$TEST_DIR"

# ============================================
# TEST 1: Create silo with silo-ignite
# ============================================
log_info "TEST 1: Create silo with silo-ignite"
"$SILO_IGNITE" hotel-paris --path "$TEST_DIR" --domain "travel" --skip-verify 2>/dev/null

if [ -d "$TEST_DIR/hotel-paris" ]; then
    log_pass "Silo directory created"
else
    log_fail "Silo directory not created"
fi

cd "$TEST_DIR/hotel-paris"

# ============================================
# TEST 2: Verify .silo manifest
# ============================================
log_info "TEST 2: Verify .silo manifest"

if [ -f ".silo" ]; then
    log_pass ".silo exists"
else
    log_fail ".silo not found"
fi

# Check required fields
NAME=$(jq -r '.name' .silo 2>/dev/null || echo "")
if [ "$NAME" = "hotel-paris" ]; then
    log_pass ".silo.name correct"
else
    log_fail ".silo.name incorrect: $NAME"
fi

DOMAIN=$(jq -r '.domain' .silo 2>/dev/null || echo "")
if [ "$DOMAIN" = "travel" ]; then
    log_pass ".silo.domain correct"
else
    log_fail ".silo.domain incorrect: $DOMAIN"
fi

# ============================================
# TEST 3: Verify justfile
# ============================================
log_info "TEST 3: Verify justfile"

if [ -f "justfile" ]; then
    log_pass "justfile exists"
else
    log_fail "justfile not found"
fi

# Check key recipes exist (check if just verify works)
if just verify >/dev/null 2>&1; then
    log_pass "verify recipe works"
else
    log_fail "verify recipe not working"
fi

if just harvest harvest.jsonl >/dev/null 2>&1; then
    log_pass "harvest recipe works"
else
    log_fail "harvest recipe not working"
fi

# ============================================
# TEST 4: Verify schema
# ============================================
log_info "TEST 4: Verify schema"

if [ -f "schema.json" ]; then
    log_pass "schema.json exists"
else
    log_fail "schema.json not found"
fi

# Validate schema is valid JSON
if jq '.' schema.json >/dev/null 2>&1; then
    log_pass "schema.json is valid JSON"
else
    log_fail "schema.json is invalid JSON"
fi

# ============================================
# TEST 5: Run just verify
# ============================================
log_info "TEST 5: Run just verify"

if just verify >/dev/null 2>&1; then
    log_pass "just verify passes"
else
    log_fail "just verify fails"
fi

# ============================================
# TEST 6: Create test data and harvest
# ============================================
log_info "TEST 6: Test harvest pipeline"

# Create test data
cat > harvest.jsonl << 'EOF'
{"id": "test-1", "timestamp": "2026-04-06T10:00:00Z", "status": "pending", "data": {"room": "101", "guest": "Alice"}}
{"id": "test-2", "timestamp": "2026-04-06T11:00:00Z", "status": "pending", "data": {"room": "102", "guest": "Bob"}}
{"id": "test-3", "timestamp": "2026-04-06T12:00:00Z", "status": "pending", "data": {"room": "103", "guest": "Carol"}}
EOF

if just harvest >/dev/null 2>&1; then
    log_pass "just harvest succeeds"
else
    log_fail "just harvest fails"
fi

# Check data was processed
DATA_COUNT=$(jq -s 'length' data.jsonl 2>/dev/null || echo 0)
if [ "$DATA_COUNT" -eq 3 ]; then
    log_pass "3 entries in data.jsonl"
else
    log_fail "Expected 3 entries, got $DATA_COUNT"
fi

# ============================================
# TEST 7: Run process
# ============================================
log_info "TEST 7: Test process"

if just process >/dev/null 2>&1; then
    log_pass "just process succeeds"
else
    log_fail "just process fails"
fi

# Check entries were marked processed
PROCESSED=$(jq -c 'select(.status == "processed")' data.jsonl 2>/dev/null | jq -s 'length' || echo 0)
if [ "$PROCESSED" -ge 3 ]; then
    log_pass "Entries marked processed"
else
    log_fail "Entries not marked processed"
fi

# ============================================
# TEST 8: Flush to output
# ============================================
log_info "TEST 8: Test flush"

if just flush >/dev/null 2>&1; then
    log_pass "just flush succeeds"
else
    log_fail "just flush fails"
fi

# Check output was created
OUTPUT_COUNT=$(jq -s 'length' final_output.jsonl 2>/dev/null || echo 0)
if [ "$OUTPUT_COUNT" -ge 3 ]; then
    log_pass "$OUTPUT_COUNT entries in final_output.jsonl"
else
    log_fail "Expected entries in output"
fi

# ============================================
# TEST 9: Status command
# ============================================
log_info "TEST 9: Test status"

if just status >/dev/null 2>&1; then
    log_pass "just status succeeds"
else
    log_fail "just status fails"
fi

# ============================================
# SUMMARY
# ============================================
echo ""
echo "========================================"
echo "Test Summary"
echo "========================================"
echo "PASSED: $PASS"
echo "FAILED: $FAIL"
echo ""

if [ $FAIL -eq 0 ]; then
    echo -e "${GREEN}ALL TESTS PASSED${NC}"
    exit 0
else
    echo -e "${RED}SOME TESTS FAILED${NC}"
    exit 1
fi

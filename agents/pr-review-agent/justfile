# pr-review-agent justfile

PR := "2"  # Default PR number

# Poll once
poll pr=PR:
    @./src/pr-review-agent poll {{pr}}

# Watch for new comments (every 5 minutes)
watch pr=PR:
    @./src/pr-review-agent watch {{pr}}

# Show current status
status pr=PR:
    @./src/pr-review-agent status {{pr}}

# Help
help:
    @./src/pr-review-agent help

{
  "name": "silo_template",
  "version": "1.0.0",
  "description": "Just-Silo template with gamma-loop auto-inheritance",
  "created": "2026-04-11",
  "silo_type": "template",
  "gamma_loop": {
    "enabled": true,
    "telemetry_dir": "telemetry",
    "debriefs_dir": "debriefs",
    "playbooks_dir": "playbooks"
  },
  "interface": {
    "engine": "justfile",
    "schema": "schema.json",
    "queries": "queries.json",
    "input": "harvest.jsonl",
    "active_state": "data.jsonl",
    "quarantine": "quarantine.jsonl",
    "output": "final_output.jsonl"
  },
  "phases": [
    "verify",
    "harvest",
    "process",
    "flush",
    "stats"
  ],
  "PHI_references": [
    "PHI-13: Workflow Durability",
    "PHI-14: Architectural Specialisation",
    "COG-12: Deductive Minimalist"
  ],
  "markers_dir": "markers",
  "checkpoint_system": true
}

# High-Integrity Environment (Deductive Minimalism, COG-12)
set shell := ["bash", "-o", "pipefail", "-c"]
set export := true

DATA_FILE      := "data.jsonl"
HARVEST_FILE   := "harvest.jsonl"
QUARANTINE_FILE := "quarantine.jsonl"
OUTPUT_FILE    := "final_output.jsonl"
SCHEMA_FILE    := "schema.json"
QUERIES_FILE   := "queries.json"
PIPELINE_FILE  := "pipeline.json"
MARKERS_DIR    := "markers"
SCRIPTS_DIR    := "scripts"

# === CORE WORKFLOW ===

default:
	@echo "Silo Recipes:"
	@just --list --justfile {{justfile()}} 2>&1 | grep -v "^#" | grep -v "Available recipes" | grep -v "^$"
	@echo ""
	@echo "Run 'just help' for overview"

# === HELP ===

# Progressive disclosure help - the safety rail
# Usage: just help           -> overview (rendered with glow if available)
#        just help <verb>    -> specific command help
help target="":
	@if [ "{{target}}" = "" ]; then \
		./{{SCRIPTS_DIR}}/help_render.sh; \
	elif [ "{{target}}" = "harvest" ]; then \
		echo "HARVEST - Ingest and validate data"; \
		echo ""; \
		echo "USAGE: just harvest [source=harvest.jsonl]"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  1. Confirms prerequisites (verify)"; \
		echo "  2. Reads source file"; \
		echo "  3. Validates against schema.json"; \
		echo "  4. Writes valid entries to data.jsonl"; \
		echo "  5. Writes invalid entries to quarantine.jsonl"; \
		echo "  6. Shows stats"; \
	elif [ "{{target}}" = "status" ]; then \
		echo "STATUS - Pipeline observability dashboard"; \
		echo ""; \
		echo "USAGE: just status"; \
		echo ""; \
		echo "WHAT IT SHOWS:"; \
		echo "  AGENTS      - Who owns which stage"; \
		echo "  STAGES      - DONE/RUNNING/PENDING per stage"; \
		echo "  THROUGHPUT  - Active/Quarantined/Archived counts"; \
		echo "  STUCK       - Stages idle > 60 minutes"; \
		echo "  ALERTS      - Critical items"; \
	elif [ "{{target}}" = "stuck" ]; then \
		echo "STUCK - Detect stalled stages"; \
		echo ""; \
		echo "USAGE: just stuck [minutes=60]"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Shows stages that completed more than N minutes ago"; \
		echo "  (Implies no subsequent stage ran - pipeline stalled)"; \
	elif [ "{{target}}" = "who" ]; then \
		echo "WHO - Who is on what stage"; \
		echo ""; \
		echo "USAGE: just who"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Shows which agent owns which stage (from pipeline.json)"; \
	elif [ "{{target}}" = "stages" ]; then \
		echo "STAGES - Stage-by-stage status"; \
		echo ""; \
		echo "USAGE: just stages"; \
		echo ""; \
		echo "WHAT IT SHOWS:"; \
		echo "  DONE/RUNNING/PENDING for each stage"; \
		echo "  Shows age for DONE stages"; \
	elif [ "{{target}}" = "throughput" ]; then \
		echo "THROUGHPUT - Processing metrics"; \
		echo ""; \
		echo "USAGE: just throughput"; \
		echo ""; \
		echo "WHAT IT SHOWS:"; \
		echo "  Active entries (data.jsonl count)"; \
		echo "  Quarantined entries (quarantine.jsonl count)"; \
		echo "  Archived entries (final_output.jsonl count)"; \
	elif [ "{{target}}" = "audit" ]; then \
		echo "AUDIT - Completion history"; \
		echo ""; \
		echo "USAGE: just audit"; \
		echo ""; \
		echo "WHAT IT SHOWS:"; \
		echo "  Chronological list of completed stages"; \
		echo "  Agent that completed each"; \
		echo "  Timestamp of completion"; \
	elif [ "{{target}}" = "alerts" ]; then \
		echo "ALERTS - Surface critical items"; \
		echo ""; \
		echo "USAGE: just alerts"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Reads data.jsonl"; \
		echo "  Filters for entries exceeding critical threshold"; \
		echo "  Configured in justfile (edit .FIELD and .THRESHOLD)"; \
	elif [ "{{target}}" = "flush" ]; then \
		echo "FLUSH - Archive processed data"; \
		echo ""; \
		echo "USAGE: just flush"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Moves entries with status=processed to final_output.jsonl"; \
		echo "  Keeps non-processed entries in data.jsonl"; \
		echo "  Shows updated stats"; \
	elif [ "{{target}}" = "claim" ]; then \
		echo "CLAIM - Own a stage (multi-agent)"; \
		echo ""; \
		echo "USAGE: just claim stage"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Creates stage.lock with agent ID"; \
		echo "  Marks you as owner"; \
	elif [ "{{target}}" = "wait" ]; then \
		echo "WAIT - Block until ready (multi-agent)"; \
		echo ""; \
		echo "USAGE: just wait marker"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Blocks until marker.lock or marker.done exists"; \
		echo "  Polls every 5 seconds"; \
	elif [ "{{target}}" = "done" ]; then \
		echo "DONE - Mark stage complete (multi-agent)"; \
		echo ""; \
		echo "USAGE: just done marker"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Converts marker.lock to marker.done"; \
		echo "  Signals downstream agents"; \
	elif [ "{{target}}" = "heartbeat" ]; then \
		echo "HEARTBEAT - Keep claims alive"; \
		echo ""; \
		echo "USAGE: just heartbeat"; \
		echo ""; \
		echo "WHAT IT DOES:"; \
		echo "  Touches all lock files"; \
		echo "  Prevents cleanup from removing your claim"; \
	else \
		echo "Unknown: {{target}}"; \
		echo "Run 'just help' for command list"; \
	fi

# Usage: just verify
# What: Checks schema, queries, and jq are present
# When: First thing to run when entering a silo
verify:
	@test -f {{SCHEMA_FILE}} && echo "  schema ok" || (echo "  MISSING schema.json"; exit 1)
	@test -f {{QUERIES_FILE}} && echo "  queries ok" || (echo "  MISSING queries.json"; exit 1)
	@command -v jq >/dev/null 2>&1 && echo "  jq ok" || echo "  jq MISSING"
	@command -v glow >/dev/null 2>&1 && echo "  glow ok" || echo "  glow MISSING (optional)"
	@command -v gum >/dev/null 2>&1 && echo "  gum ok" || echo "  gum MISSING (optional)"

# 2. Sieve: validate input against schema
# Usage: just harvest [source=harvest.jsonl]
# What: Validates data against schema, splits valid/quarantined
# When: Before processing - ingest fresh data
harvest source=(HARVEST_FILE):
	@just verify
	@if [ ! -f "{{source}}" ]; then echo "ERROR: '{{source}}' not found"; exit 1; fi
	@> {{DATA_FILE}} && > {{QUARANTINE_FILE}}
	# Reads each line, validates required fields, writes valid to data.jsonl
	# Replace with your schema validation:
	# Example: jq -c 'if .field1 and .field2 then . else empty end'
	@cat {{source}} | jq -c '.' >> {{DATA_FILE}} 2>/dev/null || true
	@just stats

# 3. Process: run the domain script
# Usage: just process
# What: Runs process.sh to transform data
# When: After harvest, before flush
process:
	@./process.sh

# === OBSERVE: Pipeline Observability ===

# Aggregate pipeline health - THE MAIN COMMAND
# Uses gum for pretty output if available
# Usage: just status
# What: Shows agents, stages, throughput, stuck, alerts
# When: Anytime you want to know what's happening
status:
	@if command -v gum >/dev/null 2>&1; then \
		./{{SCRIPTS_DIR}}/status_pretty.sh; \
	else \
		./{{SCRIPTS_DIR}}/status_plain.sh; \
	fi

# Who is on what stage
who:
	@echo "  AGENTS:"
	@if [ -f {{PIPELINE_FILE}} ]; then \
		jq -r '.stages[] | "  \(.id): \(.agent)"' {{PIPELINE_FILE}}; \
	else \
		echo "  (no pipeline.json - add stages)"; \
	fi

# Stage-by-stage status (raw)
stages:
	@./{{SCRIPTS_DIR}}/status_stages.sh

# Detect stalled stages (default: 60 minutes)
# Usage: just stuck [minutes]
stuck threshold:
	@./{{SCRIPTS_DIR}}/status_stuck.sh {{threshold}}

# Throughput metrics (raw)
throughput:
	@./{{SCRIPTS_DIR}}/status_throughput.sh

# Audit trail
audit:
	@./{{SCRIPTS_DIR}}/status_audit.sh

# === CHECK ===

# Surface entries exceeding your critical threshold
# Example: just add this to alerts: select(.moisture > 15)
alerts:
	@if [ -f {{DATA_FILE}} ]; then jq -c 'select(.<FIELD> > <THRESHOLD>)' {{DATA_FILE}} || echo "  (no alerts)"; else echo "  (no data)"; fi

stats:
	@echo "Active: $([ -f {{DATA_FILE}} ] && jq -s 'length' {{DATA_FILE}} || echo 0)"
	@echo "Quarantine: $([ -f {{QUARANTINE_FILE}} ] && jq -s 'length' {{QUARANTINE_FILE}} || echo 0)"
	@echo "Output: $([ -f {{OUTPUT_FILE}} ] && jq -s 'length' {{OUTPUT_FILE}} || echo 0)"

# Run a named filter from queries.json
# Filters are defined in queries.json under .filters.<name>.jq
query filter:
	@FILTER_JQ=$$(jq -r '.filters["{{filter}}"].jq' {{QUERIES_FILE}})
	@jq -c "$$FILTER_JQ" {{DATA_FILE}}

# Human-readable summary: counts + any critical alerts
report:
	@just stats && just alerts

# 5. Flush: move completed to final_output.jsonl
# Usage: just flush
# What: Moves processed entries to final_output.jsonl
# When: After processing, to archive completed work
flush:
	@if [ ! -f {{DATA_FILE}} ]; then echo "Nothing to flush"; exit 0; fi
	@jq -c 'select(.status == "processed")' {{DATA_FILE}} >> {{OUTPUT_FILE}} 2>/dev/null || true
	@jq -c 'select(.status != "processed")' {{DATA_FILE}} > {{DATA_FILE}}.tmp
	@mv {{DATA_FILE}}.tmp {{DATA_FILE}}
	@just stats

# === MAINTENANCE ===

self-test:
	@just verify
	@echo "SELF-TEST: PASSED"

clean:
	@rm -f {{DATA_FILE}} {{QUARANTINE_FILE}} {{OUTPUT_FILE}}
	@echo "done"

install-deps:
	@command -v jq >/dev/null 2>&1 && echo "  jq ok" || echo "  jq MISSING"
	@command -v just >/dev/null 2>&1 && echo "  just ok" || echo "  just MISSING"
	@command -v glow >/dev/null 2>&1 && echo "  glow ok" || echo "  glow MISSING (optional)"
	@command -v gum >/dev/null 2>&1 && echo "  gum ok" || echo "  gum MISSING (optional)"

compact:
	@jq -c 'select(.status == "processed") | del(.internal_trace)' {{DATA_FILE}} >> {{OUTPUT_FILE}} 2>/dev/null
	@jq -c 'select(.status != "processed")' {{DATA_FILE}} > {{DATA_FILE}}.tmp
	@mv {{DATA_FILE}}.tmp {{DATA_FILE}}

# === COST TRACKING ===

# Log a task to the cost ledger
# Usage: just silo-cost-log agent="scout-smoke" task="recon" model="minimax-2.7-4k" status="done" [duration_s]
silo-cost-log agent="unnamed" task="-" model="minimax-2.7-4k" status="done" duration_s="0":
	@mkdir -p pipeline
	@LEDGER=pipeline/history.jsonl bash {{SCRIPTS_DIR}}/silo_cost.sh "{{agent}}" "{{task}}" "{{model}}" "{{status}}" "{{duration_s}}"

# Show cost ledger summary
# Usage: just silo-cost
silo-cost:
	@if [ ! -f pipeline/history.jsonl ]; then echo "  (no ledger — run silo-cost-log first)"; exit 0; fi
	@echo "=== COST LEDGER ==="
	@wc -l < pipeline/history.jsonl | xargs echo "ENTRIES:"
	@echo ""
	@echo "PER-AGENT:"
	@jq -c '[.agent, .model, .status, .duration_s, .cost_usd]' pipeline/history.jsonl | while IFS= read -r line; do agent=$(echo "$line" | jq -r '.[0]'); model=$(echo "$line" | jq -r '.[1]'); status=$(echo "$line" | jq -r '.[2]'); dur=$(echo "$line" | jq -r '.[3]'); cost=$(echo "$line" | jq -r '.[4]'); echo "  $agent  $model  $status  ${dur}s  \$$cost"; done || true
	@echo ""
	@echo "TOTALS:"
	@jq -s '"  Total tasks: \(length)", "  Total cost: $" + (reduce .[].cost_usd as $x (0; . + $x) | tostring), "  Total duration: \(reduce .[].duration_s as $d (0; . + $d))s"' pipeline/history.jsonl | tr -d '"'
	@echo ""
	@echo "  NOTE: Estimates assume 2k in + 800 out tokens/task."
	@printf '  Rates: minimax-2.7-4k $0.05/M in / $0.10/M out\n'

# Show cost by agent group
silo-cost-by-agent:
	@LEDGER=pipeline/history.jsonl bash {{SCRIPTS_DIR}}/silo_cost_by_agent.sh

# Archive old ledger entries (>30 days)
cost-archive:
	@mkdir -p pipeline
	@if [ ! -f pipeline/history.jsonl ]; then echo "Nothing to archive"; exit 0; fi
	@ARCHIVE="pipeline/history_$$(date +%Y%m%d).jsonl"
	@jq 'select(now - (\(.ts / 1000)) < 2592000)' pipeline/history.jsonl > "$$ARCHIVE" 2>/dev/null || true
	@echo "Archived: $$ARCHIVE"

# Clear the cost ledger
cost-clear:
	@rm -f pipeline/history.jsonl
	@echo "Ledger cleared"

# === MULTI-AGENT COORDINATION ===

lock marker:
	@mkdir -p {{MARKERS_DIR}}
	@AGENT_ID=$$(hostname -s)_$$(date +%s)
	@echo "{\"agent\":\"$$AGENT_ID\",\"at\":\"$$(date -Iseconds)\"}" > {{MARKERS_DIR}}/{{marker}}.lock
	@echo "LOCKED: {{marker}}"

is-locked marker:
	@test -f {{MARKERS_DIR}}/{{marker}}.lock && echo "LOCKED" || echo "UNLOCKED"

is-done marker:
	@test -f {{MARKERS_DIR}}/{{marker}}.done && echo "DONE" || echo "NOT_DONE"

wait marker:
	@mkdir -p {{MARKERS_DIR}}
	@echo "Waiting for {{marker}}..."
	@while [ ! -f {{MARKERS_DIR}}/{{marker}}.lock ] && [ ! -f {{MARKERS_DIR}}/{{marker}}.done ]; do sleep 5; done
	@echo "{{marker}} ready"

done marker:
	@mkdir -p {{MARKERS_DIR}}
	@if [ -f {{MARKERS_DIR}}/{{marker}}.lock ]; then mv {{MARKERS_DIR}}/{{marker}}.lock {{MARKERS_DIR}}/{{marker}}.done; fi
	@touch {{MARKERS_DIR}}/{{marker}}.done
	@echo "DONE: {{marker}}"

claim stage:
	@mkdir -p {{MARKERS_DIR}}
	@AGENT_ID=$$(hostname -s)_$$(date +%s)
	@echo "{\"agent\":\"$$AGENT_ID\",\"stage\":\"{{stage}}\",\"claimed\":\"$$(date -Iseconds)\"}" > {{MARKERS_DIR}}/{{stage}}.lock
	@echo "CLAIMED: {{stage}} by $$AGENT_ID"

heartbeat:
	@mkdir -p {{MARKERS_DIR}}
	@for l in {{MARKERS_DIR}}/*.lock; do \
		if [ -f "$$l" ]; then \
			touch "$$l"; \
			stage=$$(basename "$$l" .lock); \
			echo "  heartbeat: $$stage"; \
		fi; \
	done
	@echo "Heartbeats recorded"

cleanup:
	@mkdir -p {{MARKERS_DIR}}
	@find {{MARKERS_DIR}}/ -name "*.lock" -mmin +60 -delete 2>/dev/null || true
	@echo "Cleaned stale locks"

coordination:
	@echo "=== COORDINATION STATUS ==="
	@mkdir -p {{MARKERS_DIR}}
	@ls {{MARKERS_DIR}}/*.lock {{MARKERS_DIR}}/*.done 2>/dev/null || echo "  No markers"

# === GAMMA-LOOP: Knowledge Persistence ===

# Run the gamma-loop: Observe → Measure → Learn → Adjust → Log
# Usage: just gamma [workflow]
# What: Measures entropy, logs telemetry, suggests improvements
# When: End of session or after significant work
gamma workflow="session":
	@SILO_ROOT="$(pwd)" SILO_SESSION="${SILO_SESSION:-$(hostname)_$(date +%s)}" bash {{SCRIPTS_DIR}}/gamma-loop.sh "{{workflow}}"

# Log a workflow run for entropy tracking
# Usage: just telemetry-log workflow=harvest status=success duration_s=42
telemetry-log workflow="-" status="success" duration_s="0" entries="0":
	@mkdir -p telemetry
	@jq -n --arg ts "$(date +%s)" --arg workflow "{{workflow}}" --arg status "{{status}}" --arg dur "{{duration_s}}" --arg session "${SILO_SESSION:-}" '{ts: $ts | tonumber, workflow: $workflow, status: $status, duration_s: $dur | tonumber, session: $session}' >> telemetry/runs.jsonl
	@echo "Logged: {{workflow}} ({{status}}) {{duration_s}}s"

# Show entropy trend from telemetry
# Usage: just entropy
entropy:
	@if [ ! -f telemetry/entropy.jsonl ]; then echo "  (no telemetry — run telemetry-log first)"; exit 0; fi
	@echo "=== ENTROPY TREND ==="
	@tail -10 telemetry/entropy.jsonl | jq -s 'sort_by(.ts) | .[] | "\(.workflow): \(.entropy * 100 | floor)%"' 2>/dev/null || echo "  (parse error)"
	@echo ""
	@echo "GUIDE:"
	@echo "  0-30%  Low entropy — process is stable"
	@echo "  30-60% Moderate — some variability"
	@echo "  60-100% High — process needs attention"

# Check for high-entropy events needing attention
# Usage: just telemetry-alerts
telemetry-alerts:
	@if [ ! -f telemetry/runs.jsonl ]; then echo "  (no telemetry)"; exit 0; fi
	@echo "=== TELEMETRY ALERTS ==="
	@if grep -q '"entropy":' telemetry/runs.jsonl 2>/dev/null; then tail -20 telemetry/runs.jsonl | jq -c 'select(.entropy > 0.5)' 2>/dev/null | while read -r line; do echo "  ⚠ $line"; done; else echo "  (no entropy > 50% in recent runs)"; fi

# Show telemetry summary
telemetry:
	@echo "=== TELEMETRY SUMMARY ==="
	@mkdir -p telemetry
	@RUNS=$(wc -l < telemetry/runs.jsonl 2>/dev/null || echo 0)
	@echo "Runs logged: $RUNS"
	@if [ -f telemetry/entropy.jsonl ]; then AVG_ENTROPY=$(tail -20 telemetry/entropy.jsonl | jq -s 'map(.entropy) | add / length' 2>/dev/null || echo "N/A"); echo "Avg entropy (last 20): $AVG_ENTROPY"; fi
	@ls -la telemetry/ 2>/dev/null || echo "  (empty)"

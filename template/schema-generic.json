{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Silo Data Entry",
  "description": "Canonical structure for silo input data. Replace properties with your domain.",
  "type": "object",
  "required": ["timestamp", "id"],
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the entry"
    },
    "id": {
      "type": "string",
      "description": "Unique identifier for this entry"
    },
    "status": {
      "type": "string",
      "description": "Processing status",
      "enum": ["pending", "processed", "exported", "quarantined"],
      "default": "pending"
    },
    "data": {
      "type": "object",
      "description": "Domain-specific payload. Replace with your schema."
    },
    "source": {
      "type": "string",
      "description": "Origin identifier for data lineage"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Categorization tags"
    }
  },
  "additionalProperties": true
}